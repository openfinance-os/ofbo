{
  "name": "ofbo",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "gen": "pnpm --filter @ofbo/contracts gen",
    "build": "pnpm -r --if-present build",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:smoke": "vitest run --project smoke",
    "test:integrity": "node scripts/test-integrity.mjs",
    "verify:contract": "pnpm --filter @ofbo/bff verify:contract",
    "docs:check": "node scripts/doc-link-check.mjs",
    "db:apply": "pnpm --filter @ofbo/db apply",
    "db:seed": "pnpm --filter @ofbo/db seed",
    "db:reset": "pnpm --filter @ofbo/db reset",
    "test:coverage": "vitest run --project unit --coverage",
    "test:coverage:full": "vitest run --project unit --project integration --coverage --coverage.include='services/bff/src/**' --coverage.include='packages/db/src/**' --coverage.include='packages/contracts/src/**' --coverage.include='packages/synthetic-data/src/**' --coverage.include='packages/redaction/src/**' --coverage.include='packages/release-evidence/src/**' --coverage.thresholds.lines=0 --coverage.thresholds.statements=0 --coverage.thresholds.functions=0 --coverage.thresholds.branches=0",
    "db:seed:demo": "pnpm --filter @ofbo/db seed:demo",
    "demo:fault": "bash scripts/demo-fault.sh",
    "demo:break": "pnpm --filter @ofbo/bff demo:break",
    "demo:ingest": "pnpm --filter @ofbo/bff demo:ingest"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
