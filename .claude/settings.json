{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "bgIsolation": "worktree"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree-policy.sh",
            "timeout": 10,
            "statusMessage": "Worktree-isolation policy"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pii-guard.sh",
            "timeout": 10,
            "statusMessage": "PII guard"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/spec-tripwire.sh",
            "timeout": 10,
            "statusMessage": "Spec tripwire"
          }
        ]
      }
    ]
  }
}
